@model IEnumerable<DoAnWeb.Models.Review>

@{
    ViewData["Title"] = "Quản lý đánh giá - Admin";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-5 animate-slide-up">
        <div>
            <h2 class="fw-bold mb-1"><i class="fas fa-comments me-2 text-danger"></i>Quản lý <span class="text-danger">Đánh giá</span></h2>
            <p class="text-muted small mb-0">Kiểm duyệt, phê duyệt hoặc xóa các bình luận từ khách hàng.</p>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden animate-fade-in p-4 bg-white">
        <div class="table-responsive">
            <table id="reviewsTable" class="table table-hover align-middle mb-0 w-100">
                <thead class="bg-light border-0">
                    <tr class="text-muted small text-uppercase fw-bold border-0">
                        <th class="ps-4 py-3 border-0">Khách hàng</th>
                        <th class="py-3 border-0">Bất động sản</th>
                        <th class="py-3 border-0">Đánh giá</th>
                        <th class="py-3 border-0">Nội dung</th>
                        <th class="py-3 border-0">Ngày gửi</th>
                        <th class="py-3 border-0">Trạng thái</th>
                        <th class="text-end pe-4 py-3 border-0" data-orderable="false">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="border-0">
                    @foreach (var item in Model)
                    {
                        <tr class="border-bottom">
                            <td class="ps-4 py-4">
                                <div class="fw-bold text-dark">@(item.User?.FullName ?? "N/A")</div>
                                <div class="small text-muted">@item.User?.Email</div>
                            </td>
                            <td>
                                <div class="small fw-bold">@item.Property?.Title</div>
                            </td>
                            <td>
                                <div class="text-warning">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <i class="@(i <= item.Rating ? "fas" : "far") fa-star"></i>
                                    }
                                </div>
                            </td>
                            <td>
                                <div class="small text-muted text-truncate" style="max-width: 200px;" title="@item.Comment">
                                    @item.Comment
                                </div>
                            </td>
                            <td>
                                <div class="small">@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                            </td>
                            <td>
                                @if (item.IsApproved)
                                {
                                    <span class="badge bg-soft-success rounded-pill px-3 py-2" style="font-size: 0.7rem;">Đã duyệt</span>
                                }
                                else
                                {
                                    <span class="badge bg-soft-warning rounded-pill px-3 py-2" style="font-size: 0.7rem;">Chờ duyệt</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <div class="d-flex justify-content-end gap-2">
                                    @if (!item.IsApproved)
                                    {
                                        <form asp-action="Approve" asp-route-id="@item.ReviewId" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-success rounded-pill px-3 shadow-sm">Duyệt</button>
                                        </form>
                                    }
                                    <form asp-action="Delete" asp-route-id="@item.ReviewId" method="post" class="d-inline" onsubmit="return confirm('Bạn có chắc chắn muốn xóa đánh giá này?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3 shadow-sm">Xóa</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#reviewsTable').DataTable({
                "language": {
                    "url": "//cdn.datatables.net/plug-ins/1.13.7/i18n/vi.json"
                },
                "order": [[4, 'desc']],
                "pageLength": 10,
                "responsive": true
            });
        });
    </script>
}

<style>
    .bg-soft-success { background: rgba(25, 135, 84, 0.1); color: #198754; }
    .bg-soft-warning { background: rgba(255, 193, 7, 0.1); color: #ffc107; }
</style>
