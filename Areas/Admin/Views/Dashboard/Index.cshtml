@{
    ViewData["Title"] = "Admin Dashboard";
    var hotProp = ViewBag.HotProperty as DoAnWeb.Models.Property;
    var topBuyerIntent = ViewBag.TopBuyerIntent as IEnumerable<dynamic>;
}

<style>
    :root {
        --primary-red: #ff385c;
        --soft-red: #fff1f3;
    }
    .card-stat {
        border: none;
        border-radius: 20px;
        transition: transform 0.3s;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        border: 1px solid #f0f0f0;
    }
    .card-stat:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 25px rgba(0,0,0,0.1);
    }
    .stat-icon {
        width: 50px;
        height: 50px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        margin-bottom: 15px;
    }
    .bg-soft-red { background: var(--soft-red); color: var(--primary-red); }
</style>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <h2 class="fw-bold"><i class="fas fa-chart-line me-2 text-danger"></i>Trung tâm <span class="text-danger">Quản trị</span></h2>
        <div class="text-muted small fw-bold">Hôm nay, @DateTime.Now.ToString("dd/MM/yyyy")</div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="card card-stat p-4">
                <div class="stat-icon bg-soft-red"><i class="fas fa-home"></i></div>
                <h6 class="text-muted small text-uppercase fw-bold mb-1">Tổng tài sản</h6>
                <h3 class="fw-bold mb-0">@ViewBag.TotalProperties</h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card card-stat p-4">
                <div class="stat-icon bg-soft-red"><i class="fas fa-calendar-alt"></i></div>
                <h6 class="text-muted small text-uppercase fw-bold mb-1">Tổng lịch hẹn</h6>
                <h3 class="fw-bold mb-0">@ViewBag.TotalAppointments</h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card card-stat p-4">
                <div class="stat-icon bg-soft-red"><i class="fas fa-clock"></i></div>
                <h6 class="text-muted small text-uppercase fw-bold mb-1">Đang chờ duyệt</h6>
                <h3 class="fw-bold mb-0 text-danger">@ViewBag.PendingAppointments</h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card card-stat p-4">
                <div class="stat-icon bg-soft-red"><i class="fas fa-eye"></i></div>
                <h6 class="text-muted small text-uppercase fw-bold mb-1">Tổng lượt xem</h6>
                <h3 class="fw-bold mb-0">@ViewBag.TotalViews</h3>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-lg-8">
            <div class="card card-stat p-4 mb-4">
                <h5 class="fw-bold mb-4">Biểu đồ lịch hẹn (7 ngày qua)</h5>
                <canvas id="appointmentChart" style="max-height: 300px;"></canvas>
            </div>

            <div class="card card-stat p-4">
                <h5 class="fw-bold mb-4"><i class="fas fa-medal text-warning me-2"></i>Top Buyer Intent</h5>
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr class="small text-uppercase text-muted">
                                <th>Bất động sản</th>
                                <th>Lượt yêu thích</th>
                                <th>Giá</th>
                                <th>Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (topBuyerIntent != null)
                            {
                                foreach (var item in topBuyerIntent)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-bold">@item.Property.Title</div>
                                            <div class="small text-muted">@item.Property.District, @item.Property.City</div>
                                        </td>
                                        <td><span class="badge bg-soft-red rounded-pill px-3">@item.FavCount ❤️</span></td>
                                        <td class="text-danger fw-bold">@item.Property.Price.ToString("C0", new System.Globalization.CultureInfo("vi-VN"))</td>
                                        <td><a href="/Admin/Properties/Details/@item.Property.PropertyId" class="btn btn-sm btn-light rounded-pill px-3">Xem</a></td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card card-stat h-100 p-4">
                <h5 class="fw-bold mb-4">BĐS Hot nhất</h5>
                @if (hotProp != null)
                {
                    <div class="text-center">
                        <div class="position-relative mb-3">
                            <img src="@(hotProp.ImagesProperties.FirstOrDefault(i => i.IsMain)?.ImageUrl ?? hotProp.ImagesProperties.FirstOrDefault()?.ImageUrl)" 
                                 class="rounded-4 w-100 shadow-sm" style="height: 220px; object-fit: cover;">
                            <div class="position-absolute top-0 end-0 m-2">
                                <span class="badge bg-danger rounded-pill px-3">@ViewBag.HotPropertyFavCount <i class="fas fa-heart ms-1"></i></span>
                            </div>
                        </div>
                        <h5 class="fw-bold mb-2">@hotProp.Title</h5>
                        <p class="text-danger fw-bold h4 mb-3">@hotProp.Price.ToString("C0", new System.Globalization.CultureInfo("vi-VN"))</p>
                        <div class="d-flex justify-content-center gap-4 mb-4 text-muted small">
                            <span><i class="fas fa-eye me-1"></i> @hotProp.ViewCount xem</span>
                            <span><i class="fas fa-map-marker-alt me-1"></i> @hotProp.District</span>
                        </div>
                        <a asp-action="Details" asp-controller="Properties" asp-route-id="@hotProp.PropertyId" class="btn btn-danger rounded-pill w-100 py-3 fw-bold shadow">QUẢN LÝ NIÊM YẾT</a>
                    </div>
                }
                else
                {
                    <div class="text-center py-5 opacity-25">
                        <i class="fas fa-box-open fa-4x mb-3"></i>
                        <p class="fst-italic">Chưa có dữ liệu hot</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const ctx = document.getElementById('appointmentChart').getContext('2d');
        new Chart(ctx, {
            type: 'line',
            data: {
                labels: @Html.Raw(Json.Serialize(ViewBag.AppointmentStatsLabels)),
                datasets: [{
                    label: 'Lượt đặt',
                    data: @Html.Raw(Json.Serialize(ViewBag.AppointmentStatsData)),
                    borderColor: '#ff385c',
                    backgroundColor: 'rgba(255, 56, 92, 0.05)',
                    borderWidth: 3,
                    fill: true,
                    tension: 0.4,
                    pointRadius: 5,
                    pointBackgroundColor: '#fff',
                    pointBorderColor: '#ff385c',
                    pointBorderWidth: 2
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    y: { beginAtZero: true, grid: { display: false }, ticks: { stepSize: 1 } },
                    x: { grid: { display: false } }
                }
            }
        });
    </script>
}
