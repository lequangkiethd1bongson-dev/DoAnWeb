@model IEnumerable<DoAnWeb.Models.ViewModels.UserViewModel>

@{
    ViewData["Title"] = "Quản lý người dùng chi tiết";
}

<div class="container-fluid py-5 px-4">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <h2 class="fw-bold mb-0">Quản lý <span class="text-danger">người dùng</span></h2>
        <a asp-action="CreateUser" class="btn btn-danger rounded-pill px-4 fw-bold shadow-sm">
            <i class="fas fa-user-plus me-2"></i>Tạo tài khoản mới
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-4 border-0 shadow-sm mb-4" role="alert">
            <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive p-4">
                <table id="usersTable" class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-3 py-3 text-uppercase small fw-bold text-muted">User Info</th>
                            <th class="py-3 text-uppercase small fw-bold text-muted">Role</th>
                            <th class="py-3 text-uppercase small fw-bold text-muted">Phone</th>
                            <th class="py-3 text-uppercase small fw-bold text-muted text-center">Verified</th>
                            <th class="py-3 text-uppercase small fw-bold text-muted text-center">Status</th>
                            <th class="pe-3 py-3 text-end text-uppercase small fw-bold text-muted">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model)
                        {
                            <tr>
                                <td class="ps-3">
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-sm bg-light rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 45px; height: 45px;">
                                            <i class="fas fa-user text-muted fs-5"></i>
                                        </div>
                                        <div>
                                            <div class="fw-bold text-dark">@user.UserName</div>
                                            <div class="small text-muted">@user.Email</div>
                                            <div class="x-small text-muted font-monospace" style="font-size: 0.7rem;">ID: @user.Id</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    @{
                                        var roleBadge = user.Role switch
                                        {
                                            "Admin" => "bg-danger",
                                            "Staff_Property" => "bg-primary",
                                            "Staff_Appointment" => "bg-info text-dark",
                                            "Staff" => "bg-success",
                                            _ => "bg-secondary"
                                        };
                                    }
                                    <span class="badge rounded-pill @roleBadge px-3">
                                        @user.Role
                                    </span>
                                </td>
                                <td>
                                    <span class="small">@(user.PhoneNumber ?? "---")</span>
                                </td>
                                <td class="text-center">
                                    @if(user.EmailConfirmed)
                                    {
                                        <i class="fas fa-check-circle text-success" title="Đã xác thực Email"></i>
                                    }
                                    else
                                    {
                                        <i class="fas fa-times-circle text-muted" title="Chưa xác thực"></i>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (user.IsLocked)
                                    {
                                        <span class="badge bg-dark rounded-pill px-2">
                                            <i class="fas fa-lock me-1"></i>Bị khóa
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-2">
                                            <i class="fas fa-unlock me-1"></i>Hoạt động
                                        </span>
                                    }
                                </td>
                                <td class="pe-3 text-end">
                                    <div class="btn-group shadow-sm rounded-pill overflow-hidden">
                                        <a asp-action="EditUserRole" asp-route-id="@user.Id" class="btn btn-sm btn-white text-dark border-end" title="Đổi Role">
                                            <i class="fas fa-user-tag"></i>
                                        </a>
                                        
                                        @if (user.IsLocked)
                                        {
                                            <form asp-action="UnlockUser" asp-route-id="@user.Id" method="post" class="d-inline">
                                                <button type="submit" class="btn btn-sm btn-white text-success border-end" title="Mở khóa tài khoản">
                                                    <i class="fas fa-lock-open"></i>
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <form asp-action="LockUser" asp-route-id="@user.Id" method="post" class="d-inline">
                                                <button type="submit" class="btn btn-sm btn-white text-warning border-end" title="Khóa tài khoản">
                                                    <i class="fas fa-lock text-dark"></i>
                                                </button>
                                            </form>
                                        }

                                        <form asp-action="DeleteUser" asp-route-id="@user.Id" method="post" class="d-inline" onsubmit="return confirm('Bạn có chắc chắn muốn xóa người dùng này?')">
                                            <button type="submit" class="btn btn-sm btn-white text-danger" title="Xóa người dùng">
                                                <i class="fas fa-trash-alt"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .avatar-sm i { color: #adb5bd !important; }
    .btn-white { background: white; transition: all 0.2s; }
    .btn-white:hover { background: #f8f9fa; transform: translateY(-1px); }
    .table-responsive { min-height: 400px; }
    div.dataTables_wrapper div.dataTables_filter input {
        border-radius: 50px;
        padding: 5px 15px;
        background-color: #f8f9fa;
        border: none;
    }
    .page-link { border-radius: 50% !important; margin: 0 3px; border: none; }
    .page-item.active .page-link { background-color: #ff385c; }
</style>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#usersTable').DataTable({
                "language": {
                    "url": "//cdn.datatables.net/plug-ins/1.13.7/i18n/vi.json"
                },
                "pageLength": 10,
                "order": [[1, "asc"]],
                "columnDefs": [
                    { "orderable": false, "targets": [3, 5] }
                ],
                "dom": '<"d-flex justify-content-between align-items-center mb-4"f>rt<"d-flex justify-content-between align-items-center mt-4"ip>'
            });
        });
    </script>
}
