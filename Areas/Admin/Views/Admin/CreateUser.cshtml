@model DoAnWeb.Models.ViewModels.CreateUserViewModel

@{
    ViewData["Title"] = "Tạo người dùng mới";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-5">
                    <h2 class="fw-bold mb-4">Tạo <span class="text-danger">người dùng</span> mới</h2>
                    
                    <form asp-action="CreateUser" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                        
                        <div class="row g-3">
                            <div class="col-md-6 mb-3">
                                <label asp-for="FullName" class="form-label fw-bold small text-uppercase">Họ và tên</label>
                                <input asp-for="FullName" class="form-control rounded-pill border-0 bg-light px-3 shadow-none" placeholder="Nguyễn Văn A" />
                                <span asp-validation-for="FullName" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="PhoneNumber" class="form-label fw-bold small text-uppercase">Số điện thoại</label>
                                <input asp-for="PhoneNumber" class="form-control rounded-pill border-0 bg-light px-3 shadow-none" placeholder="0123.456.789" />
                                <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                            </div>
                        </div>
                        
                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-bold small text-uppercase">Email</label>
                            <input asp-for="Email" class="form-control rounded-pill border-0 bg-light px-3 shadow-none" placeholder="example@gmail.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        
                        <div class="mb-3">
                            <label asp-for="Password" class="form-label fw-bold small text-uppercase">Mật khẩu</label>
                            <input asp-for="Password" class="form-control rounded-pill border-0 bg-light px-3 shadow-none" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>
                        
                        <div class="mb-4">
                            <label asp-for="Role" class="form-label fw-bold small text-uppercase">Phân quyền (Role)</label>
                            <select asp-for="Role" class="form-select rounded-pill border-0 bg-light px-3 shadow-none">
                                @foreach (var role in Model.Roles)
                                {
                                    <option value="@role">@role</option>
                                }
                            </select>
                            <span asp-validation-for="Role" class="text-danger small"></span>
                        </div>
                        
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger btn-lg rounded-pill fw-bold shadow-sm">Tạo ngay</button>
                            <a asp-action="Users" class="btn btn-link text-muted text-decoration-none small">Hủy và quay lại</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
