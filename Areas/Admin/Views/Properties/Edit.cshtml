@model DoAnWeb.Models.Property

@{
    ViewData["Title"] = "Sửa phòng trọ";
}

<h1>Chỉnh sửa phòng trọ</h1>

<div class="row">
    <div class="col-md-8">
        <form asp-action="Edit" enctype="multipart/form-data">
            <input type="hidden" asp-for="PropertyId" />
            <input type="hidden" asp-for="CreatedAt" />
            
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            <div class="card mb-4">
                <div class="card-header">Thông tin cơ bản</div>
                <div class="card-body">
                    <div class="mb-3">
                        <label asp-for="Title" class="form-label">Tiêu đề</label>
                        <input asp-for="Title" class="form-control" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Mô tả</label>
                        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Price" class="form-label">Giá thuê (VND)</label>
                            <input asp-for="Price" class="form-control" type="number" />
                            <span asp-validation-for="Price" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Area" class="form-label">Diện tích (m²)</label>
                            <input asp-for="Area" class="form-control" type="number" step="0.1" />
                            <span asp-validation-for="Area" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="City" class="form-label">Thành phố</label>
                            <input asp-for="City" class="form-control" />
                            <span asp-validation-for="City" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Address" class="form-label">Địa chỉ chi tiết</label>
                            <input asp-for="Address" class="form-control" />
                            <span asp-validation-for="Address" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Status" class="form-label">Trạng thái</label>
                        <select asp-for="Status" class="form-select">
                            <option value="Available">Trống</option>
                            <option value="Rented">Đã thuê</option>
                            <option value="Hidden">Ẩn</option>
                        </select>
                    </div>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header">Hình ảnh hiện tại</div>
                <div class="card-body">
                    <div class="row mb-3" id="imageGallery">
                        @foreach (var img in Model.ImagesProperties)
                        {
                            <div class="col-md-3 mb-3 text-center" id="img-wrapper-@img.ImageId">
                                <div class="position-relative">
                                    <img src="@img.ImageUrl" class="img-thumbnail w-100" style="height: 120px; object-fit: cover;" />
                                    <button type="button" class="btn btn-danger btn-sm position-absolute top-0 end-0 m-1" onclick="deleteImage(@img.ImageId)">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </div>
                                <div class="small mt-1 text-muted">
                                    @(img.IsMain ? "⭐ Ảnh chính" : "")
                                </div>
                            </div>
                        }
                    </div>
                    <hr />
                    <div class="mb-3">
                        <label class="form-label fw-bold">Thêm ảnh mới</label>
                        <input type="file" name="imageFiles" multiple class="form-control" accept="image/*" />
                    </div>
                </div>
            </div>

            <div class="mb-5">
                <button type="submit" class="btn btn-primary btn-lg px-5">Cập nhật</button>
                <a asp-action="Index" class="btn btn-secondary btn-lg px-5">Hủy</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function deleteImage(id) {
            if (confirm('Bạn có chắc chắn muốn xóa ảnh này?')) {
                fetch('/Admin/Properties/DeleteImage/' + id, {
                    method: 'POST',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        document.getElementById('img-wrapper-' + id).remove();
                    } else {
                        alert('Có lỗi xảy ra khi xóa ảnh.');
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('Lỗi kết nối server.');
                });
            }
        }
    </script>
}
