@model IEnumerable<DoAnWeb.Models.Property>

@{
    ViewData["Title"] = "Quản lý bất động sản";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold"><i class="fas fa-home me-2 text-danger"></i>Quản lý bất động sản</h2>
        <a asp-action="Create" class="btn btn-danger rounded-pill px-4"><i class="fas fa-plus me-2"></i>Thêm phòng mới</a>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Ảnh</th>
                        <th>Thông tin bất động sản</th>
                        <th>Vị trí & Loại</th>
                        <th>Giá & Diện tích</th>
                        <th>Trạng thái</th>
                        <th class="text-end pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        var mainImage = item.ImagesProperties.FirstOrDefault(i => i.IsMain) ?? item.ImagesProperties.FirstOrDefault();
                        <tr>
                            <td class="ps-4">
                                @if (mainImage != null)
                                {
                                    <img src="@mainImage.ImageUrl" alt="Property" class="rounded-3 shadow-sm" style="width: 100px; height: 75px; object-fit: cover;" />
                                }
                                else
                                {
                                    <div class="bg-light rounded-3 d-flex align-items-center justify-content-center text-muted" style="width: 100px; height: 75px;">
                                        <i class="fas fa-image"></i>
                                    </div>
                                }
                            </td>
                            <td>
                                <div class="fw-bold text-dark">@item.Title</div>
                                <div class="text-muted small">ID: #@item.PropertyId</div>
                            </td>
                            <td>
                                <div class="small fw-bold text-danger">@item.PropertyType</div>
                                <div class="text-muted small">@item.District, @item.City</div>
                                <div class="text-muted small"><i class="fas fa-bed me-1"></i>@item.NumberOfRooms Phòng</div>
                            </td>
                            <td>
                                <div class="fw-bold text-danger">@item.Price.ToString("C0", new System.Globalization.CultureInfo("vi-VN"))</div>
                                <div class="text-muted small">@item.Area m²</div>
                            </td>
                            <td>
                                <select class="form-select form-select-sm rounded-pill status-toggle shadow-none border-0 bg-light px-3" 
                                        data-id="@item.PropertyId" style="width: 130px;">
                                    <option value="Available" selected="@(item.Status == "Available")">Available</option>
                                    <option value="Pending" selected="@(item.Status == "Pending")">Pending</option>
                                    <option value="Sold" selected="@(item.Status == "Sold")">Sold</option>
                                </select>
                            </td>
                            <td class="text-end pe-4">
                                <div class="d-flex justify-content-end gap-2">
                                    <a asp-action="Edit" asp-route-id="@item.PropertyId" class="btn btn-sm btn-outline-warning rounded-circle" title="Chỉnh sửa">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@item.PropertyId" method="post" class="delete-form d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger rounded-circle" title="Xóa">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Xử lý đổi trạng thái AJAX
            $('.status-toggle').on('change', function() {
                const propertyId = $(this).data('id');
                const newStatus = $(this).val();
                const selectElement = $(this);

                $.ajax({
                    url: '@Url.Action("UpdateStatus", "Properties")',
                    type: 'POST',
                    data: { id: propertyId, status: newStatus },
                    success: function(response) {
                        if (response.success) {
                            Toast.fire({
                                icon: 'success',
                                title: 'Đã cập nhật trạng thái'
                            });
                        }
                    },
                    error: function() {
                        Swal.fire('Lỗi!', 'Không thể cập nhật trạng thái.', 'error');
                    }
                });
            });

            // Xử lý xác nhận xóa
            $('.delete-form').on('submit', function(e) {
                e.preventDefault();
                const form = this;
                Swal.fire({
                    title: 'Xóa bất động sản?',
                    text: "Hành động này không thể hoàn tác!",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#dc3545',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Đồng ý xóa',
                    cancelButtonText: 'Hủy'
                }).then((result) => {
                    if (result.isConfirmed) {
                        form.submit();
                    }
                });
            });

            // Toast setup
            const Toast = Swal.mixin({
                toast: true,
                position: 'top-end',
                showConfirmButton: false,
                timer: 3000,
                timerProgressBar: true
            });
        });
    </script>
}
