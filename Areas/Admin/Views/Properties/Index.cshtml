@model IEnumerable<DoAnWeb.Models.Property>

@{
    ViewData["Title"] = "Quản lý phòng trọ";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Danh sách phòng trọ</h1>
    <a asp-action="Create" class="btn btn-primary">Thêm phòng mới</a>
</div>

<table class="table table-striped table-hover mt-3 shadow-sm border rounded">
    <thead class="bg-light">
        <tr>
            <th>Ảnh</th>
            <th>Tiêu đề</th>
            <th>Địa chỉ</th>
            <th>Thành phố</th>
            <th>Giá</th>
            <th>Diện tích</th>
            <th>Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            var mainImage = item.ImagesProperties.FirstOrDefault(i => i.IsMain) ?? item.ImagesProperties.FirstOrDefault();
            <tr>
                <td>
                    @if (mainImage != null)
                    {
                        <img src="@mainImage.ImageUrl" alt="Property Image" class="rounded shadow-sm" style="width: 80px; height: 60px; object-fit: cover;" />
                    }
                    else
                    {
                        <div class="bg-secondary rounded text-white d-flex align-items-center justify-content-center" style="width: 80px; height: 60px;">No Image</div>
                    }
                </td>
                <td>@item.Title</td>
                <td>@item.Address</td>
                <td>@item.City</td>
                <td>@item.Price.ToString("C0", new System.Globalization.CultureInfo("vi-VN"))</td>
                <td>@item.Area m²</td>
                <td>
                    <div class="btn-group">
                        <a asp-action="Edit" asp-route-id="@item.PropertyId" class="btn btn-sm btn-warning">Sửa</a>
                        <a asp-action="Delete" asp-route-id="@item.PropertyId" class="btn btn-sm btn-danger">Xóa</a>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>
