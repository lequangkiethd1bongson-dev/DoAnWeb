@model IEnumerable<DoAnWeb.Models.Property>

@{
    ViewData["Title"] = "Quản lý bất động sản - Admin";
}

<style>
    .bg-soft-success { background: rgba(25, 135, 84, 0.1); color: #198754; }
    .bg-soft-warning { background: rgba(255, 193, 7, 0.1); color: #ffc107; }
    .bg-soft-danger { background: rgba(220, 53, 69, 0.1); color: #dc3545; }
    .property-thumb { transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
    .property-thumb:hover { transform: scale(1.1); z-index: 5; }
    .action-btn { width: 38px; height: 38px; display: flex; align-items: center; justify-content: center; transition: all 0.3s; }
    .action-btn:hover { transform: translateY(-3px); }
</style>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-5 animate-slide-up">
        <div>
            <h2 class="fw-bold mb-1"><i class="fas fa-city me-2 text-danger"></i>Quản lý <span class="text-danger">Niêm yết</span></h2>
            <p class="text-muted small mb-0">Hệ thống đang quản lý @Model.Count() bất động sản.</p>
        </div>
        <a asp-action="Create" class="btn btn-premium px-4"><i class="fas fa-plus me-2"></i>Thêm tài sản mới</a>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden animate-fade-in">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light border-0">
                    <tr class="text-muted small text-uppercase fw-bold border-0">
                        <th class="ps-4 py-3 border-0">Thông tin cơ bản</th>
                        <th class="py-3 border-0">Vị trí & Loại</th>
                        <th class="py-3 border-0">Giá & Diện tích</th>
                        <th class="py-3 border-0">Trạng thái</th>
                        <th class="text-end pe-4 py-3 border-0">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="border-0">
                    @foreach (var item in Model)
                    {
                        var mainImage = item.ImagesProperties.FirstOrDefault(i => i.IsMain) ?? item.ImagesProperties.FirstOrDefault();
                        <tr class="border-bottom">
                            <td class="ps-4 py-4">
                                <div class="d-flex align-items-center">
                                    <div class="me-3 position-relative">
                                        <img src="@(mainImage?.ImageUrl ?? "/images/no-image.jpg")" class="rounded-4 shadow-sm property-thumb" style="width: 100px; height: 75px; object-fit: cover;" />
                                    </div>
                                    <div>
                                        <div class="fw-bold text-dark mb-1">@item.Title</div>
                                        <div class="small text-muted letter-spacing-1">ID: #@item.PropertyId</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div class="badge bg-soft-red rounded-pill px-3 mb-2" style="font-size: 0.7rem;">@item.PropertyType</div>
                                <div class="text-muted small"><i class="fas fa-map-marker-alt me-1"></i> @item.District, @item.City</div>
                            </td>
                            <td>
                                <div class="fw-bold text-danger h6 mb-1">@item.Price.ToString("C0", new System.Globalization.CultureInfo("vi-VN"))</div>
                                <div class="text-muted small">@item.Area m² • @item.NumberOfRooms PN</div>
                            </td>
                            <td>
                                @{
                                    var statusClass = item.Status switch {
                                        "Available" => "bg-soft-success",
                                        "Pending" => "bg-soft-warning",
                                        "Sold" => "bg-soft-danger",
                                        _ => "bg-light"
                                    };
                                }
                                <select class="form-select form-select-sm rounded-pill status-toggle @statusClass border-0 px-3 fw-bold" 
                                        data-id="@item.PropertyId" style="width: 130px; font-size: 0.75rem;">
                                    <option value="Available" selected="@(item.Status == "Available")">Available</option>
                                    <option value="Pending" selected="@(item.Status == "Pending")">Pending</option>
                                    <option value="Sold" selected="@(item.Status == "Sold")">Sold</option>
                                </select>
                            </td>
                            <td class="text-end pe-4">
                                <div class="d-flex justify-content-end gap-2">
                                    <a asp-action="Details" asp-route-id="@item.PropertyId" class="btn action-btn btn-light rounded-circle shadow-sm" title="Chi tiết">
                                        <i class="fas fa-eye text-primary"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.PropertyId" class="btn action-btn btn-light rounded-circle shadow-sm" title="Chỉnh sửa">
                                        <i class="fas fa-edit text-warning"></i>
                                    </a>
                                    <button type="button" class="btn action-btn btn-light rounded-circle shadow-sm" title="Xóa" onclick="confirmDelete(@item.PropertyId)">
                                        <i class="fas fa-trash text-danger"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<form id="deleteForm" method="post" action="@Url.Action("Delete", "Properties")">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" id="deletePropertyId" />
</form>

@section Scripts {
    <script>
        function confirmDelete(id) {
            Swal.fire({
                title: 'Xác nhận xóa?',
                text: "Dữ liệu liên quan đến niêm yết này sẽ bị xóa vĩnh viễn!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ff385c',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Đúng, xóa nó!',
                cancelButtonText: 'Hủy'
            }).then((result) => {
                if (result.isConfirmed) {
                    $('#deletePropertyId').val(id);
                    $('#deleteForm').submit();
                }
            });
        }

        $(document).ready(function() {
            $('.status-toggle').on('change', function() {
                const propertyId = $(this).data('id');
                const newStatus = $(this).val();
                const $select = $(this);

                $.post('@Url.Action("UpdateStatus", "Properties")', { id: propertyId, status: newStatus }, function(res) {
                    if (res.success) {
                        // Update color classes
                        $select.removeClass('bg-soft-success bg-soft-warning bg-soft-danger');
                        if(newStatus === 'Available') $select.addClass('bg-soft-success');
                        else if(newStatus === 'Pending') $select.addClass('bg-soft-warning');
                        else if(newStatus === 'Sold') $select.addClass('bg-soft-danger');

                        Toast.fire({
                            icon: 'success',
                            title: 'Đã cập nhật trạng thái'
                        });
                    }
                });
            });

            const Toast = Swal.mixin({
                toast: true,
                position: 'top-end',
                showConfirmButton: false,
                timer: 3000,
                timerProgressBar: true
            });
        });
    </script>
}
