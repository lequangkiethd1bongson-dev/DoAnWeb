@model IEnumerable<DoAnWeb.Models.Appointment>

@{
    ViewData["Title"] = "Quản lý lịch hẹn";
}

<h1 class="mb-4">Danh sách lịch hẹn xem phòng</h1>

<div class="table-responsive shadow-sm rounded">
    <table class="table table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Ngày hẹn</th>
                <th>Người đặt</th>
                <th>Tên phòng</th>
                <th>Ghi chú</th>
                <th>Trạng thái</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.AppointmentDate.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@item.User?.Email</td>
                    <td>@item.Property?.Title</td>
                    <td>@item.Note</td>
                    <td>
                        @{
                            var badgeClass = item.Status switch
                            {
                                "Approved" => "bg-success",
                                "Cancelled" => "bg-danger",
                                "Pending" => "bg-warning text-dark",
                                _ => "bg-secondary"
                            };
                        }
                        <span class="badge @badgeClass">@item.Status</span>
                    </td>
                    <td>
                        @if (item.Status == "Pending")
                        {
                            <div class="btn-group">
                                <form asp-action="Approve" asp-route-id="@item.AppointmentId" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-outline-success">Duyệt</button>
                                </form>
                                <form asp-action="Cancel" asp-route-id="@item.AppointmentId" method="post" class="d-inline ms-1">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Hủy</button>
                                </form>
                            </div>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
