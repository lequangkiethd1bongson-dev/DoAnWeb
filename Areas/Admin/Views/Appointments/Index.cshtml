@model IEnumerable<DoAnWeb.Models.Appointment>

@{
    ViewData["Title"] = "Quản lý lịch hẹn";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold"><i class="fas fa-calendar-alt me-2 text-danger"></i>Quản lý lịch hẹn</h2>
        <div class="d-flex gap-2">
            <form asp-action="Index" method="get" class="d-flex gap-2">
                <input type="date" name="date" value="@ViewBag.DateFilter" class="form-control" />
                <input type="text" name="search" value="@ViewBag.SearchFilter" class="form-control" placeholder="Tìm tên khách, tên phòng..." style="width: 250px;" />
                <button type="submit" class="btn btn-danger"><i class="fas fa-search me-1"></i>Tìm kiếm</button>
                <a asp-action="ExportToCsv" asp-route-date="@ViewBag.DateFilter" asp-route-search="@ViewBag.SearchFilter" class="btn btn-success">
                    <i class="fas fa-file-excel me-1"></i>Xuất Excel
                </a>
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-undo"></i></a>
            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Thông tin khách hàng</th>
                        <th>Bất động sản</th>
                        <th>Thời gian hẹn</th>
                        <th>Ghi chú</th>
                        <th>Trạng thái</th>
                        <th class="text-end pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    <div class="bg-light rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">
                                        <i class="fas fa-user text-muted"></i>
                                    </div>
                                    <div>
                                        <div class="fw-bold">@item.User?.FullName</div>
                                        <div class="text-muted small">@item.User?.Email</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div class="fw-bold text-truncate" style="max-width: 200px;">@item.Property?.Title</div>
                                <div class="text-muted small">@item.Property?.District, @item.Property?.City</div>
                            </td>
                            <td>
                                <div class="fw-bold">@item.AppointmentDate.ToString("dd/MM/yyyy")</div>
                                <div class="text-muted small">@item.AppointmentDate.ToString("HH:mm")</div>
                            </td>
                            <td>
                                <small class="text-muted text-truncate d-block" style="max-width: 150px;" title="@item.Note">
                                    @(string.IsNullOrEmpty(item.Note) ? "Không có" : item.Note)
                                </small>
                            </td>
                            <td>
                                @{
                                    var badgeClass = item.Status switch
                                    {
                                        "Approved" => "bg-success text-white",
                                        "Cancelled" => "bg-danger text-white",
                                        "Pending" => "bg-warning text-dark",
                                        _ => "bg-secondary text-white"
                                    };
                                }
                                <span class="badge @badgeClass rounded-pill px-3">@item.Status</span>
                            </td>
                            <td class="text-end pe-4">
                                @if (item.Status == "Pending")
                                {
                                    <div class="d-flex justify-content-end gap-2">
                                        <form asp-action="Approve" asp-route-id="@item.AppointmentId" method="post" class="confirm-form">
                                            <button type="submit" class="btn btn-sm btn-success rounded-pill px-3">Duyệt</button>
                                        </form>
                                        <form asp-action="Cancel" asp-route-id="@item.AppointmentId" method="post" class="confirm-form">
                                            <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3">Hủy</button>
                                        </form>
                                    </div>
                                }
                                else
                                {
                                    <span class="text-muted small">N/A</span>
                                }
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <i class="fas fa-calendar-times fa-3x mb-3 d-block opacity-25"></i>
                                Không tìm thấy lịch hẹn nào.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $('.confirm-form').on('submit', function(e) {
            e.preventDefault();
            const form = this;
            const action = $(form).find('button').text().trim();
            
            Swal.fire({
                title: action === 'Duyệt' ? 'Duyệt lịch hẹn?' : 'Hủy lịch hẹn?',
                text: "Bạn có chắc chắn muốn thực hiện thao tác này?",
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: action === 'Duyệt' ? '#198754' : '#dc3545',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Đồng ý',
                cancelButtonText: 'Hủy'
            }).then((result) => {
                if (result.isConfirmed) {
                    form.submit();
                }
            });
        });
    </script>
}
