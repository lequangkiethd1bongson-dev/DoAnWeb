@{
    ViewData["Title"] = "Đăng ký";
}

<div class="row justify-content-center mt-5 pt-5">
    <div class="col-md-5">
        <div class="card shadow border-0">
            <div class="card-body p-5">
                <h2 class="fw-bold text-center mb-4">Tạo tài khoản mới</h2>
                <form asp-action="Register" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Họ và tên</label>
                        <input type="text" name="fullName" class="form-control form-control-lg" placeholder="Nhập họ tên" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Số điện thoại</label>
                        <input type="text" name="phone" class="form-control form-control-lg" placeholder="Nhập SĐT" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Email</label>
                        <input type="email" name="email" class="form-control form-control-lg" placeholder="Email của bạn" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Mật khẩu</label>
                        <input type="password" name="password" class="form-control form-control-lg" placeholder="Nhập mật khẩu" required>
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-bold">Xác nhận mật khẩu</label>
                        <input type="password" name="confirmPassword" class="form-control form-control-lg" placeholder="Nhập lại mật khẩu" required>
                    </div>
                    <button class="w-100 btn btn-lg btn-primary mb-3 py-3 fw-bold" type="submit">Đăng ký tài khoản</button>
                    <div class="text-center mt-2">
                        Đã có tài khoản? <a asp-action="Login" class="text-decoration-none fw-bold">Đăng nhập</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
