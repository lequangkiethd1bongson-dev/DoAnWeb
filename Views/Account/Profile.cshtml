@model DoAnWeb.Models.ApplicationUser

@{
    ViewData["Title"] = "Trang cá nhân";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8 animate-slide-up">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden glass-card">
                <div class="card-header bg-premium py-5 text-center text-white border-0 position-relative">
                    <div class="position-absolute top-0 start-0 w-100 h-100 bg-dark opacity-10"></div>
                    <div class="position-relative z-index-1">
                        <div class="avatar-wrapper mb-3 mx-auto shadow-lg rounded-circle bg-white p-1" style="width: 120px; height: 120px;">
                            @if (!string.IsNullOrEmpty(Model.AvatarUrl))
                            {
                                <img src="@Model.AvatarUrl" class="w-100 h-100 rounded-circle object-fit-cover" alt="Avatar" />
                            }
                            else
                            {
                                <div class="w-100 h-100 rounded-circle d-flex align-items-center justify-content-center bg-soft-red text-danger fw-bold fs-1">
                                    @Model.FullName?.Substring(0, 1).ToUpper()
                                </div>
                            }
                        </div>
                        <h2 class="fw-bold mb-1">@Model.FullName</h2>
                        <p class="opacity-75 mb-0"><i class="fas fa-certificate me-1"></i> Thành viên @Model.Status</p>
                    </div>
                </div>
                <div class="card-body p-5">
                    <h5 class="fw-bold mb-4 border-bottom pb-2">Thông tin cá nhân</h5>
                    <div class="row g-4">
                        <div class="col-md-6">
                            <label class="text-muted small text-uppercase fw-bold mb-1">Họ và tên</label>
                            <div class="d-flex align-items-center p-3 bg-light rounded-3">
                                <i class="fas fa-user text-danger me-3"></i>
                                <span class="fw-semibold">@Model.FullName</span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="text-muted small text-uppercase fw-bold mb-1">Địa chỉ Email</label>
                            <div class="d-flex align-items-center p-3 bg-light rounded-3">
                                <i class="fas fa-envelope text-danger me-3"></i>
                                <span class="fw-semibold">@Model.Email</span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="text-muted small text-uppercase fw-bold mb-1">Số điện thoại</label>
                            <div class="d-flex align-items-center p-3 bg-light rounded-3">
                                <i class="fas fa-phone text-danger me-3"></i>
                                <span class="fw-semibold">@Model.UserPhone</span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="text-muted small text-uppercase fw-bold mb-1">Ngày tham gia</label>
                            <div class="d-flex align-items-center p-3 bg-light rounded-3">
                                <i class="fas fa-calendar-alt text-danger me-3"></i>
                                <span class="fw-semibold">@Model.CreatedAt.ToString("dd/MM/yyyy")</span>
                            </div>
                        </div>
                    </div>

                    <div class="mt-5 d-flex gap-3">
                        <a asp-action="EditProfile" class="btn btn-premium px-4 border-0 shadow-sm"><i class="fas fa-edit me-2"></i>Chỉnh sửa thông tin</a>
                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="btn btn-outline-dark rounded-pill px-4"><i class="fas fa-tachometer-alt me-2"></i>Trang Quản trị</a>
                        }
                    </div>
                </div>
            </div>
            
            <div class="mt-4 text-center">
                <a asp-controller="Home" asp-action="Index" class="text-muted text-decoration-none hover-danger">
                    <i class="fas fa-arrow-left me-2"></i>Quay lại trang chủ
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-premium {
        background: var(--primary-gradient) !important;
    }
    .z-index-1 { z-index: 1; }
    .bg-soft-red { background-color: rgba(255, 56, 92, 0.1); }
</style>

@section Scripts {
    @if (TempData["Success"] != null)
    {
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
        <script>
            Swal.fire({
                icon: 'success',
                title: 'Thành công!',
                text: '@TempData["Success"]',
                confirmButtonColor: '#ff385c',
                timer: 3000
            });
        </script>
    }
}
