<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - RentalProperty</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary-red: #ff385c;
            --hover-red: #e31c5f;
            --bg-white: #ffffff;
            --text-dark: #222222;
            --text-muted: #717171;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #f8f9fa;
            color: var(--text-dark);
        }

        .navbar {
            background-color: var(--bg-white) !important;
            padding: 1rem 0;
            box-shadow: 0 1px 12px rgba(0,0,0,0.08);
        }

        .navbar-brand {
            font-size: 1.5rem;
            letter-spacing: -0.5px;
        }

        .nav-link {
            font-weight: 500;
            color: var(--text-dark) !important;
            margin: 0 10px;
            transition: color 0.2s;
        }

        .nav-link:hover {
            color: var(--primary-red) !important;
        }

        .btn-danger {
            background-color: var(--primary-red);
            border-color: var(--primary-red);
        }

        .btn-danger:hover {
            background-color: var(--hover-red);
            border-color: var(--hover-red);
        }

        .property-card {
            border: none;
            border-radius: 16px;
            overflow: hidden;
            transition: transform 0.3s, box-shadow 0.3s;
            background: #fff;
        }

        .property-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 12px 24px rgba(0,0,0,0.1);
        }

        .badge-compare {
            background-color: var(--primary-red);
            color: white;
            font-size: 0.7rem;
            padding: 2px 6px;
            border-radius: 50px;
            vertical-align: top;
            margin-left: -5px;
        }

        footer {
            background: #fff;
            padding: 40px 0;
            margin-top: 60px;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light sticky-top">
            <div class="container">
                <a class="navbar-brand fw-bold text-danger" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="fas fa-building me-1"></i>NhaTro<span class="text-dark">Pro</span>
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-lg-inline-flex justify-content-between">
                    <ul class="navbar-nav mx-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Trang chủ</a>
                        </li>
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle fw-bold" href="#" id="adminDropdown" role="button" data-bs-toggle="dropdown">
                                    <i class="fas fa-user-shield me-1"></i>Quản trị
                                </a>
                                <ul class="dropdown-menu shadow border-0 rounded-4 p-2 mt-2">
                                    <li><a class="dropdown-item rounded-3 py-2" asp-area="Admin" asp-controller="Dashboard" asp-action="Index"><i class="fas fa-chart-line me-2"></i>Dashboard</a></li>
                                    <li><a class="dropdown-item rounded-3 py-2" asp-area="Admin" asp-controller="Amenities" asp-action="Index"><i class="fas fa-list me-2"></i>Tiện ích</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item rounded-3 py-2" asp-area="Admin" asp-controller="Properties" asp-action="Index"><i class="fas fa-home me-2"></i>Quản lý phòng</a></li>
                                    <li><a class="dropdown-item rounded-3 py-2" asp-area="Admin" asp-controller="Appointments" asp-action="Index"><i class="fas fa-calendar-alt me-2"></i>Quản lý lịch hẹn</a></li>
                                </ul>
                            </li>
                        }
                    </ul>
                    <ul class="navbar-nav">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Compare" asp-action="Index">
                                    <i class="fas fa-exchange-alt"></i> So sánh
                                    <span class="badge-compare d-none" id="compareCount">0</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Favorites" asp-action="Index"><i class="fas fa-heart text-danger"></i> Yêu thích</a>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle fw-bold" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown">
                                    <i class="fas fa-user-circle me-1"></i> @User.Identity.Name
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-4 p-2 mt-2">
                                    <li><a class="dropdown-item rounded-3 py-2" asp-area="" asp-controller="MyAppointments" asp-action="Index"><i class="fas fa-calendar-check me-2"></i>Lịch của tôi</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                            <button type="submit" class="dropdown-item rounded-3 py-2 text-danger">Đăng xuất</button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Account" asp-action="Login">Đăng nhập</a>
                            </li>
                            <li class="nav-item ms-lg-2">
                                <a class="btn btn-danger rounded-pill px-4" asp-area="" asp-controller="Account" asp-action="Register">Đăng ký</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container pb-5">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-5 bg-white py-5">
        <div class="container">
            <div class="row">
                <div class="col-md-6 text-center text-md-start">
                    <a class="navbar-brand fw-bold text-danger mb-3 d-inline-block" href="#">
                        <i class="fas fa-building me-1"></i>NhaTroPro
                    </a>
                    <p class="small">Hệ thống đặt phòng trọ trực tuyến hàng đầu Việt Nam.</p>
                </div>
                <div class="col-md-6 text-center text-md-end">
                    <p class="mb-0 small">&copy; 2026 - DoAnWeb Rental Property</p>
                    <div class="mt-2">
                        <a href="#" class="text-muted me-3 small text-decoration-none">Chính sách bảo mật</a>
                        <a href="#" class="text-muted small text-decoration-none">Điều khoản sử dụng</a>
                    </div>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script>
        $(document).ready(function() {
            // Placeholder for comparison list count
            const updateCompareCount = () => {
                const count = JSON.parse(localStorage.getItem('compareIds') || '[]').length;
                if (count > 0) {
                    $('#compareCount').text(count).removeClass('d-none');
                } else {
                    $('#compareCount').addClass('d-none');
                }
            };
            updateCompareCount();
            window.addEventListener('storage', updateCompareCount);
            window.addEventListener('compareUpdated', updateCompareCount);
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
