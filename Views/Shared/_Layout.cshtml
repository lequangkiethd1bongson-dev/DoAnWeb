<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="NhaTroPro - Hệ thống cho thuê phòng trọ, căn hộ, nhà ở uy tín hàng đầu. Tìm kiếm không gian sống lý tưởng của bạn ngay hôm nay." />
    <meta name="keywords" content="thuê phòng trọ, tìm phòng trọ, chung cư mini, nhà nguyên căn, căn hộ dịch vụ" />
    <title>@ViewData["Title"] - NhaTroPro</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/index.css" asp-append-version="true" />
    <style>
        /* Styles unified in index.css */
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light sticky-top glass-nav">
            <div class="container">
                <a class="navbar-brand fw-bold text-danger animate-fade-in" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="fas fa-building-circle-check me-1"></i>NhaTro<span class="text-dark">Pro</span>
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-lg-inline-flex justify-content-between">
                    <ul class="navbar-nav mx-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Trang chủ</a>
                        </li>
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle fw-bold" href="#" id="adminDropdown" role="button" data-bs-toggle="dropdown">
                                    <i class="fas fa-user-shield me-1"></i>Quản trị
                                </a>
                                <ul class="dropdown-menu shadow border-0 rounded-4 p-2 mt-2">
                                    <li><a class="dropdown-item rounded-3 py-2" asp-area="Admin" asp-controller="Dashboard" asp-action="Index"><i class="fas fa-chart-line me-2"></i>Dashboard</a></li>
                                    <li><a class="dropdown-item rounded-3 py-2" asp-area="Admin" asp-controller="Amenities" asp-action="Index"><i class="fas fa-list me-2"></i>Tiện ích</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item rounded-3 py-2" asp-area="Admin" asp-controller="Properties" asp-action="Index"><i class="fas fa-home me-2"></i>Quản lý phòng</a></li>
                                    <li><a class="dropdown-item rounded-3 py-2" asp-area="Admin" asp-controller="Appointments" asp-action="Index"><i class="fas fa-calendar-alt me-2"></i>Quản lý lịch hẹn</a></li>
                                </ul>
                            </li>
                        }
                    </ul>
                    <ul class="navbar-nav">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Compare" asp-action="Index">
                                    <i class="fas fa-exchange-alt"></i> So sánh
                                    <span class="badge-compare d-none" id="compareCount">0</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Favorites" asp-action="Index"><i class="fas fa-heart text-danger"></i> Yêu thích</a>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle fw-bold" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown">
                                    <i class="fas fa-user-circle me-1"></i> @User.Identity.Name
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-4 p-2 mt-2">
                                    <li><a class="dropdown-item rounded-3 py-2" asp-area="" asp-controller="MyAppointments" asp-action="Index"><i class="fas fa-calendar-check me-2"></i>Lịch của tôi</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                            <button type="submit" class="dropdown-item rounded-3 py-2 text-danger">Đăng xuất</button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Account" asp-action="Login">Đăng nhập</a>
                            </li>
                            <li class="nav-item ms-lg-2">
                                <a class="btn btn-premium rounded-pill px-4" asp-area="" asp-controller="Account" asp-action="Register">Đăng ký</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container pb-5">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    @if (User.Identity?.IsAuthenticated == true && !User.IsInRole("Admin"))
    {
        <!-- Floating Chat Widget -->
        <div id="chat-widget" class="position-fixed bottom-0 end-0 m-4 shadow-lg rounded border" style="z-index: 1050; width: 350px; background: white; display: none; flex-direction: column;">
            <div class="bg-primary text-white p-3 rounded-top d-flex justify-content-between align-items-center" id="chat-widget-header" style="cursor: pointer;">
                <h6 class="mb-0"><i class="fas fa-headset me-2"></i> Hỗ trợ trực tuyến</h6>
                <i class="fas fa-times"></i>
            </div>
            <div id="chat-widget-body" style="height: 350px; display: flex; flex-direction: column;">
                <div id="chat-widget-messages" class="p-3 flex-grow-1" style="overflow-y: auto; background-color: #f8f9fa;">
                    <div class="text-center text-muted small mt-2 mb-3">Bắt đầu trò chuyện với hỗ trợ viên</div>
                </div>
                <div class="p-2 border-top">
                    <div class="input-group">
                        <input type="text" id="chat-widget-input" class="form-control" placeholder="Nhập tin nhắn..." autocomplete="off">
                        <button class="btn btn-primary px-3" id="chat-widget-send"><i class="fas fa-paper-plane"></i></button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Chat Button -->
        <button id="chat-widget-btn" class="btn btn-primary rounded-circle position-fixed bottom-0 end-0 m-4 shadow-lg d-flex justify-content-center align-items-center" style="width: 65px; height: 65px; z-index: 1040;">
            <i class="fas fa-comment-dots fs-3"></i>
        </button>
    }

    <footer class="footer mt-auto py-5 glass-card border-0 rounded-0" style="background: white !important;">
        <div class="container">
            <div class="row g-5">
                <div class="col-lg-4">
                    <a class="navbar-brand fw-bold text-danger mb-3 d-inline-block fs-3" asp-controller="Home" asp-action="Index">
                        <i class="fas fa-building-circle-check me-2"></i>NhaTroPro
                    </a>
                    <p class="text-muted mb-4 pe-lg-5">Hệ thống cho thuê phòng trọ và căn hộ cao cấp, mang đến không gian sống hiện đại và tiện nghi cho mọi người.</p>
                    <div class="social-links d-flex">
                        <a href="#" class="btn btn-light rounded-circle me-2 shadow-sm"><i class="fab fa-facebook-f text-primary"></i></a>
                        <a href="#" class="btn btn-light rounded-circle me-2 shadow-sm"><i class="fab fa-instagram text-danger"></i></a>
                        <a href="#" class="btn btn-light rounded-circle shadow-sm"><i class="fab fa-youtube text-danger"></i></a>
                    </div>
                </div>
                <div class="col-lg-2 col-md-4">
                    <h6 class="fw-bold mb-4">Discovery</h6>
                    <ul class="list-unstyled">
                        <li class="mb-2"><a href="/" class="text-decoration-none text-muted small hover-danger">Phòng mới nhất</a></li>
                        <li class="mb-2"><a href="#" class="text-decoration-none text-muted small hover-danger">Khu vực TP.HCM</a></li>
                        <li class="mb-2"><a href="#" class="text-decoration-none text-muted small hover-danger">Chung cư cao cấp</a></li>
                        <li class="mb-2"><a href="#" class="text-decoration-none text-muted small hover-danger">Nhà nguyên căn</a></li>
                    </ul>
                </div>
                <div class="col-lg-2 col-md-4">
                    <h6 class="fw-bold mb-4">Công ty</h6>
                    <ul class="list-unstyled">
                        <li class="mb-2"><a href="#" class="text-decoration-none text-muted small hover-danger">Về chúng tôi</a></li>
                        <li class="mb-2"><a href="#" class="text-decoration-none text-muted small hover-danger">Tin tức</a></li>
                        <li class="mb-2"><a href="#" class="text-decoration-none text-muted small hover-danger">Liên hệ</a></li>
                        <li class="mb-2"><a href="#" class="text-decoration-none text-muted small hover-danger">Tuyển dụng</a></li>
                    </ul>
                </div>
                <div class="col-lg-4 col-md-4">
                    <h6 class="fw-bold mb-4">Đăng ký nhận tin</h6>
                    <p class="text-muted small mb-4">Nhận thông báo về những căn phòng giá tốt nhất sớm nhất.</p>
                    <div class="input-group mb-3 bg-light rounded-pill p-1 overflow-hidden border">
                        <input type="text" class="form-control border-0 bg-transparent shadow-none" placeholder="Email của bạn">
                        <button class="btn btn-premium rounded-pill px-4" type="button">Gửi</button>
                    </div>
                </div>
            </div>
            <hr class="my-5 opacity-10">
            <div class="row align-items-center">
                <div class="col-md-6 text-center text-md-start">
                    <p class="mb-0 small text-muted">&copy; 2026 NhaTroPro. All rights reserved.</p>
                </div>
                <div class="col-md-6 text-center text-md-end">
                    <div class="legal-links mt-3 mt-md-0">
                        <a href="#" class="text-muted small text-decoration-none me-4 hover-danger">Bảo mật</a>
                        <a href="#" class="text-muted small text-decoration-none hover-danger">Điều khoản</a>
                    </div>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script>
        $(document).ready(function() {
            // Placeholder for comparison list count
            const updateCompareCount = () => {
                let ids = JSON.parse(localStorage.getItem('compareIds') || '[]');
                // Convert all to strings to avoid duplicates and ensure consistency
                ids = ids.map(id => id.toString());
                localStorage.setItem('compareIds', JSON.stringify(ids));
                
                const count = ids.length;
                if (count > 0) {
                    $('#compareCount').text(count).removeClass('d-none');
                } else {
                    $('#compareCount').addClass('d-none');
                }
            };
            updateCompareCount();
            window.addEventListener('storage', updateCompareCount);
            window.addEventListener('compareUpdated', updateCompareCount);
        });
    </script>
    @if (User.Identity?.IsAuthenticated == true && !User.IsInRole("Admin"))
    {
        <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
        <script>
            $(document).ready(function() {
                const connection = new signalR.HubConnectionBuilder()
                    .withUrl("/chatHub")
                    .build();

                // Load chat history from DB
                $.get('/Chat/GetMyMessages', function(data) {
                    if (data && data.length > 0) {
                        $('#chat-widget-messages').empty();
                        data.forEach(function(msg) {
                            if (msg.isAdminSender) {
                                const msgHtml = `<div class="d-flex flex-column align-items-start mb-2">
                                                    <div class="bg-white p-2 rounded shadow-sm border" style="max-width: 85%;">
                                                        <strong>Hỗ trợ viên:</strong> ${msg.content}
                                                    </div>
                                                 </div>`;
                                $('#chat-widget-messages').append(msgHtml);
                            } else {
                                const msgHtml = `<div class="d-flex flex-column align-items-end mb-2">
                                                    <div class="bg-primary text-white p-2 rounded shadow-sm" style="max-width: 85%;">
                                                        ${msg.content}
                                                    </div>
                                                 </div>`;
                                $('#chat-widget-messages').append(msgHtml);
                            }
                        });
                        $('#chat-widget-messages').scrollTop($('#chat-widget-messages')[0].scrollHeight);
                    }
                });

                $('#chat-widget-btn').click(function() {
                    $(this).hide();
                    $('#chat-widget').css('display', 'flex');
                    $('#chat-widget-messages').scrollTop($('#chat-widget-messages')[0].scrollHeight);
                    $(this).removeClass('btn-danger').addClass('btn-primary');
                });

                $('#chat-widget-header').click(function() {
                    $('#chat-widget').hide();
                    $('#chat-widget-btn').show();
                });

                connection.on("ReceiveMessage", function(senderId, message, timestamp) {
                    const msgHtml = `<div class="d-flex flex-column align-items-start mb-2">
                                        <div class="bg-white p-2 rounded shadow-sm border" style="max-width: 85%;">
                                            <strong>Hỗ trợ viên:</strong> ${message}
                                        </div>
                                     </div>`;
                    $('#chat-widget-messages').append(msgHtml);
                    $('#chat-widget-messages').scrollTop($('#chat-widget-messages')[0].scrollHeight);
                    
                    if ($('#chat-widget').is(':hidden')) {
                        $('#chat-widget-btn').removeClass('btn-primary').addClass('btn-danger');
                    }
                });

                connection.start().catch(function(err) {
                    console.error(err.toString());
                });

                $('#chat-widget-send').click(function() {
                    const message = $('#chat-widget-input').val().trim();
                    if(!message) return;
                    
                    $('#chat-widget-input').val('');
                    // Send to empty receiver (auto-assigned to admin by server)
                    connection.invoke("SendMessage", "", message).then(function() {
                        const msgHtml = `<div class="d-flex flex-column align-items-end mb-2">
                                            <div class="bg-primary text-white p-2 rounded shadow-sm" style="max-width: 85%;">
                                                ${message}
                                            </div>
                                         </div>`;
                        $('#chat-widget-messages').append(msgHtml);
                        $('#chat-widget-messages').scrollTop($('#chat-widget-messages')[0].scrollHeight);
                    }).catch(function(err) {
                        console.error(err.toString());
                    });
                });

                $('#chat-widget-input').keypress(function(e) {
                    if(e.which === 13) {
                        $('#chat-widget-send').click();
                    }
                });
            });
        </script>
    }
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
