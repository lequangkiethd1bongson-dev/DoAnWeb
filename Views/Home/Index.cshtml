@model IEnumerable<DoAnWeb.Models.Property>

@{
    ViewData["Title"] = "Trang chủ";
}

<style>
    .property-card {
        border: none;
        border-radius: 20px;
        overflow: hidden;
        transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        margin-bottom: 40px;
        background: #fff;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        border: 1px solid rgba(0,0,0,0.03);
    }

    .property-card:hover {
        transform: translateY(-10px) scale(1.02);
        box-shadow: 0 25px 50px rgba(0,0,0,0.12);
        border-color: rgba(255, 56, 92, 0.2);
    }

    .gallery-container {
        display: flex;
        gap: 6px;
        height: 320px;
        background: #f0f0f0;
        overflow: hidden;
    }

    .gallery-main {
        flex: 2.5;
        height: 100%;
        object-fit: cover;
        transition: transform 0.8s ease;
    }

    .property-card:hover .gallery-main {
        transform: scale(1.1);
    }

    .gallery-side {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .gallery-item {
        height: 50%;
        object-fit: cover;
        transition: opacity 0.3s, filter 0.3s;
    }

    .property-card:hover .gallery-item {
        filter: brightness(0.9);
    }

    .property-content {
        padding: 25px;
        transition: background 0.3s;
    }

    .property-card:hover .property-content {
        background: linear-gradient(to bottom, #ffffff, #fffdfd);
    }

    .property-title {
        font-size: 1.4rem;
        font-weight: 700;
        color: #111;
        margin-bottom: 8px;
        text-decoration: none;
        display: block;
        transition: color 0.3s;
    }

    .property-card:hover .property-title {
        color: #ff385c;
    }

    .property-info {
        color: #717171;
        font-size: 0.95rem;
        margin-bottom: 12px;
        display: flex;
        gap: 15px;
        align-items: center;
    }

    .property-price {
        color: #ff385c;
        font-size: 1.6rem;
        font-weight: 800;
        letter-spacing: -0.5px;
    }

    .favorite-btn {
        background: white;
        border: none;
        color: #b0b0b0;
        transition: all 0.3s;
        font-size: 1.6rem;
        width: 45px;
        height: 45px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }

    .favorite-btn:hover {
        transform: scale(1.1);
        color: #ff385c;
    }

    .favorite-btn.active {
        color: #ff385c;
        animation: heartBeat 0.5s;
    }

    @@keyframes heartBeat {
        0% { transform: scale(1); }
        50% { transform: scale(1.3); }
        100% { transform: scale(1); }
    }
</style>

<style>
    .hero-wrapper {
        position: relative;
        margin-bottom: 80px;
    }

    .carousel-item {
        height: 450px;
    }

    .carousel-item img {
        object-fit: cover;
        height: 100%;
        filter: brightness(0.7);
    }

    .search-overlay {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 100%;
        z-index: 10;
        text-align: center;
        color: white;
    }

    .search-card {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        border-radius: 50px;
        padding: 10px;
        display: inline-block;
        width: 90%;
        max-width: 850px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.2);
    }
</style>

<div class="hero-wrapper">
    <!-- Hero Slider -->
    <div id="heroCarousel" class="carousel slide carousel-fade" data-bs-ride="carousel">
        <div class="carousel-inner rounded-4 overflow-hidden">
            <div class="carousel-item active">
                <img src="https://images.unsplash.com/photo-1560448204-603b3fc33ddc?auto=format&fit=crop&w=1200" class="d-block w-100" alt="Slider 1">
            </div>
            <div class="carousel-item">
                <img src="https://images.unsplash.com/photo-1502672260266-1c1ef2d93688?auto=format&fit=crop&w=1200" class="d-block w-100" alt="Slider 2">
            </div>
            <div class="carousel-item">
                <img src="https://images.unsplash.com/photo-1484154218962-a197022b5858?auto=format&fit=crop&w=1200" class="d-block w-100" alt="Slider 3">
            </div>
        </div>
    </div>

    <!-- Search Overlay -->
    <div class="search-overlay">
        <h1 class="display-4 fw-bold mb-4 drop-shadow">Tìm kiếm chỗ ở đẳng cấp</h1>
        <div class="search-card mx-auto">
            <form asp-action="Index" method="get" class="row g-0 align-items-center">
                <div class="col-md-4 border-end">
                    <div class="input-group px-3">
                        <span class="text-danger me-2"><i class="fas fa-map-marker-alt"></i></span>
                        <input type="text" name="city" value="@ViewBag.City" class="form-control border-0 shadow-none p-0" placeholder="Bạn muốn ở đâu?">
                    </div>
                </div>
                <div class="col-md-3 border-end">
                    <input type="number" name="minPrice" value="@ViewBag.MinPrice" class="form-control border-0 shadow-none text-center" placeholder="Giá từ">
                </div>
                <div class="col-md-3">
                    <input type="number" name="maxPrice" value="@ViewBag.MaxPrice" class="form-control border-0 shadow-none text-center" placeholder="Đến">
                </div>
                <div class="col-md-2 p-1">
                    <button type="submit" class="btn btn-danger rounded-pill w-100 py-3 fw-bold shadow-sm">
                        <i class="fas fa-search me-1"></i> Tìm
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="container">
    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-12">
                <div class="property-card">
                    <!-- Gallery Top -->
                    <div class="gallery-container">
                        @{
                            var imgs = item.ImagesProperties.OrderByDescending(i => i.IsMain).ToList();
                            if (imgs.Count > 0)
                            {
                                <img src="@imgs[0].ImageUrl" class="gallery-main" alt="Main">
                                if (imgs.Count > 1)
                                {
                                    <div class="gallery-side">
                                        <img src="@imgs[1].ImageUrl" class="gallery-item" alt="Thumb 1">
                                        @if (imgs.Count > 2)
                                        {
                                            <div class="position-relative h-50">
                                                <img src="@imgs[2].ImageUrl" class="w-100 h-100 object-fit-cover" alt="Thumb 2">
                                                @if (imgs.Count > 3)
                                                {
                                                    <div class="position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center bg-dark bg-opacity-50 text-white fw-bold">
                                                        +@(imgs.Count - 2)
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </div>
                                }
                            }
                        }
                    </div>

                    <!-- Info Bottom -->
                    <div class="property-content">
                        <div class="d-flex justify-content-between align-items-start">
                            <a asp-action="Details" asp-route-id="@item.PropertyId" class="property-title">@item.Title</a>
                            @{
                                bool isFav = ViewBag.FavoriteIds != null && ((List<int>)ViewBag.FavoriteIds).Contains(item.PropertyId);
                            }
                            <button class="favorite-btn @(isFav ? "active" : "")" onclick="toggleFavorite(@item.PropertyId, this)">
                                <i class="fas fa-heart"></i>
                            </button>
                        </div>
                        <div class="property-info">
                            <span>2 PN</span> • <span>Hướng Tây Nam</span> • <span>Nhà ngõ, hẻm</span>
                        </div>
                        <div class="d-flex align-items-baseline gap-3">
                            <span class="property-price">@item.Price.ToString("C0", new System.Globalization.CultureInfo("vi-VN"))/tháng</span>
                            <span class="h5 mb-0">@item.Area m²</span>
                        </div>
                        <div class="text-muted mt-2">
                            <i class="fas fa-map-marker-alt"></i> @item.City
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function toggleFavorite(id, btn) {
            fetch('/Favorites/Toggle?propertyId=' + id, {
                method: 'POST',
                headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() }
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    if (data.isFavorite) $(btn).addClass('active');
                    else $(btn).removeClass('active');
                } else {
                    window.location.href = '/Account/Login';
                }
            });
        }
    </script>
}
