@model IEnumerable<DoAnWeb.Models.Property>

@{
    ViewData["Title"] = "Trang chủ";
}

<style>
    .hero-section {
        background: linear-gradient(rgba(255,255,255,0.8), rgba(255,255,255,0.9)), url('https://images.unsplash.com/photo-1560518883-ce09059eeffa?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80');
        background-size: cover;
        background-position: center;
        padding: 120px 0 80px;
        text-align: center;
    }

    .search-container {
        max-width: 1000px;
        margin: -50px auto 0;
        background: #fff;
        padding: 30px;
        border-radius: 24px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.06);
        border: 1px solid #eee;
        position: relative;
        z-index: 10;
    }

    .filter-label {
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        color: var(--text-muted);
        margin-bottom: 5px;
        display: block;
    }

    .property-card {
        border: 1px solid #eee;
        background: #fff;
    }

    .compare-checkbox {
        position: absolute;
        top: 15px;
        left: 15px;
        z-index: 5;
    }

    .compare-badge {
        background: rgba(0,0,0,0.6);
        color: #fff;
        padding: 4px 12px;
        border-radius: 50px;
        font-size: 0.75rem;
        backdrop-filter: blur(4px);
    }
</style>

<div class="hero-section mb-5">
    <div class="container">
        <h1 class="display-3 fw-bold mb-3">Tìm kiếm <span class="text-danger">không gian</span> sống</h1>
        <p class="lead text-muted mb-0">Hàng ngàn lựa chọn bất động sản phù hợp với phong cách của bạn.</p>
    </div>
</div>

<div class="container">
    <div class="search-container mb-5">
        <form asp-action="Index" method="get">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="filter-label">Bạn muốn tìm gì?</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-0 text-danger"><i class="fas fa-search"></i></span>
                        <input type="text" name="keyword" value="@ViewBag.Keyword" class="form-control border-0 shadow-none ps-0" placeholder="Từ khóa, tên phòng...">
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="filter-label">Vị trí</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-0 text-danger"><i class="fas fa-map-marker-alt"></i></span>
                        <input type="text" name="district" value="@ViewBag.District" class="form-control border-0 shadow-none ps-0" placeholder="Quận/Huyện">
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="filter-label">Loại tài sản</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-0 text-danger"><i class="fas fa-home"></i></span>
                        <select name="propertyType" class="form-select border-0 shadow-none ps-0">
                            <option value="">Tất cả</option>
                            <option value="House" selected="@(ViewBag.PropertyType == "House")">Nhà ở</option>
                            <option value="Land" selected="@(ViewBag.PropertyType == "Land")">Đất</option>
                            <option value="Apartment" selected="@(ViewBag.PropertyType == "Apartment")">Chung cư</option>
                        </select>
                    </div>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-danger w-100 rounded-pill py-3 fw-bold mt-2">Tìm kiếm</button>
                </div>
            </div>
            
            <div class="row g-3 mt-2 pt-3 border-top">
                <div class="col-md-3">
                    <div class="d-flex align-items-center">
                        <span class="text-muted small me-2">Giá:</span>
                        <input type="number" name="minPrice" value="@ViewBag.MinPrice" class="form-control form-control-sm border-0 border-bottom rounded-0 px-1 shadow-none" placeholder="Từ" style="width: 80px;">
                        <span class="mx-1 ms-2">-</span>
                        <input type="number" name="maxPrice" value="@ViewBag.MaxPrice" class="form-control form-control-sm border-0 border-bottom rounded-0 px-1 shadow-none" placeholder="Đến" style="width: 80px;">
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="d-flex align-items-center">
                        <span class="text-muted small me-2">Diện tích:</span>
                        <input type="number" name="minArea" value="@ViewBag.MinArea" class="form-control form-control-sm border-0 border-bottom rounded-0 px-1 shadow-none" placeholder="Từ" style="width: 60px;">
                        <span class="mx-2 ms-2">-</span>
                        <input type="number" name="maxArea" value="@ViewBag.MaxArea" class="form-control form-control-sm border-0 border-bottom rounded-0 px-1 shadow-none" placeholder="Đến" style="width: 60px;">
                    </div>
                </div>
                <div class="col-md-6 text-end">
                    <div class="btn-group">
                        <a href="/" class="btn btn-link text-muted text-decoration-none small"><i class="fas fa-undo me-1"></i>Xóa lọc</a>
                        <button type="button" class="btn btn-link text-danger text-decoration-none small ms-3" id="goCompareBtn">
                            <i class="fas fa-exchange-alt me-1"></i>Xem so sánh
                        </button>
                    </div>
                </div>
            </div>
        </form>
    </div>

    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-lg-4 col-md-6">
                <div class="property-card h-100 position-relative">
                    <!-- Compare Toggle -->
                    <div class="form-check compare-checkbox">
                        <input class="form-check-input compare-toggle" type="checkbox" value="@item.PropertyId" id="comp-@item.PropertyId">
                        <label class="form-check-label compare-badge d-none" for="comp-@item.PropertyId">So sánh</label>
                    </div>

                    @{
                        var mainImg = item.ImagesProperties.FirstOrDefault(i => i.IsMain) ?? item.ImagesProperties.FirstOrDefault();
                    }
                    <div class="position-relative overflow-hidden" style="height: 240px;">
                        <img src="@(mainImg?.ImageUrl ?? "/images/no-image.jpg")" class="w-100 h-100 object-fit-cover transition-transform" alt="Property">
                        @{
                            bool isFav = ViewBag.FavoriteIds != null && ((List<int>)ViewBag.FavoriteIds).Contains(item.PropertyId);
                        }
                        <button class="btn btn-light rounded-circle shadow-sm position-absolute top-0 end-0 m-3 p-0 d-flex align-items-center justify-content-center @(isFav ? "text-danger" : "text-muted")" 
                                style="width: 40px; height: 40px; z-index: 5;" onclick="toggleFavorite(@item.PropertyId, this)">
                            <i class="fas fa-heart"></i>
                        </button>
                    </div>

                    <div class="p-4">
                        <div class="text-danger small fw-bold mb-2">@item.PropertyType</div>
                        <h5 class="fw-bold mb-3"><a asp-action="Details" asp-route-id="@item.PropertyId" class="text-dark text-decoration-none">@item.Title</a></h5>
                        
                        <div class="d-flex align-items-center text-muted small mb-3">
                            <i class="fas fa-map-marker-alt text-danger me-2"></i>@item.District, @item.City
                        </div>

                        <div class="row g-0 py-3 border-top border-bottom mb-3">
                            <div class="col-4 border-end text-center">
                                <div class="small text-muted"><i class="fas fa-bed me-1"></i>Phòng</div>
                                <div class="fw-bold">@item.NumberOfRooms</div>
                            </div>
                            <div class="col-4 border-end text-center">
                                <div class="small text-muted"><i class="fas fa-expand me-1"></i>DT</div>
                                <div class="fw-bold">@item.Area m²</div>
                            </div>
                            <div class="col-4 text-center">
                                <div class="small text-muted"><i class="fas fa-star me-1 text-warning"></i>Vote</div>
                                <div class="fw-bold">@(item.Reviews.Any() ? Math.Round(item.Reviews.Average(r => r.Rating), 1) : 0)</div>
                            </div>
                        </div>

                        <div class="d-flex align-items-center justify-content-between">
                            <div class="fw-bold text-danger fs-5">@item.Price.ToString("C0", new System.Globalization.CultureInfo("vi-VN"))</div>
                            <a asp-action="Details" asp-route-id="@item.PropertyId" class="btn btn-outline-dark btn-sm rounded-pill px-3">Chi tiết</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Load selected comparison items from localStorage
            let compareIds = JSON.parse(localStorage.getItem('compareIds') || '[]');
            $('.compare-toggle').each(function() {
                if (compareIds.includes($(this).val())) {
                    $(this).prop('checked', true);
                    $(this).next().removeClass('d-none');
                }
            });

            // Handle toggle
            $('.compare-toggle').on('change', function() {
                const id = $(this).val();
                if (this.checked) {
                    if (compareIds.length >= 3) {
                        alert('Bạn chỉ có thể chọn tối đa 3 bất động sản để so sánh.');
                        this.checked = false;
                        return;
                    }
                    if (!compareIds.includes(id)) compareIds.push(id);
                    $(this).next().removeClass('d-none');
                } else {
                    compareIds = compareIds.filter(i => i != id);
                    $(this).next().addClass('d-none');
                }
                localStorage.setItem('compareIds', JSON.stringify(compareIds));
                window.dispatchEvent(new Event('compareUpdated'));
            });

            $('#goCompareBtn').on('click', function() {
                const ids = JSON.parse(localStorage.getItem('compareIds') || '[]');
                if (ids.length < 1) {
                    Swal.fire('Lưu ý', 'Vui lòng chọn ít nhất 1 bất động sản để so sánh.', 'info');
                    return;
                }
                window.location.href = '@Url.Action("Index", "Compare")?ids=' + ids.join(',');
            });
        });

        function toggleFavorite(id, btn) {
            fetch('/Favorites/Toggle?propertyId=' + id, {
                method: 'POST',
                headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() }
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    if (data.isFavorite) $(btn).addClass('text-danger').removeClass('text-muted');
                    else $(btn).removeClass('text-danger').addClass('text-muted');
                } else {
                    window.location.href = '/Account/Login';
                }
            });
        }
    </script>
}
