@model DoAnWeb.Models.Property

@{
    ViewData["Title"] = Model.Title;
}

<style>
    /* Styles unified in index.css */
</style>

<div class="container py-5">
    <div class="row g-4">
        <div class="col-lg-8">
            <!-- Breadcrumb -->
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-danger text-decoration-none small fw-bold">Trang chủ</a></li>
                    <li class="breadcrumb-item active small text-muted" aria-current="page">@Model.Title</li>
                </ol>
            </nav>

            <!-- Gallery -->
            <div id="propertyGallery" class="carousel slide shadow rounded-4 overflow-hidden mb-5" data-bs-ride="carousel">
                <div class="carousel-inner">
                    @if (Model.ImagesProperties.Any())
                    {
                        var count = 0;
                        foreach (var img in Model.ImagesProperties.OrderByDescending(i => i.IsMain))
                        {
                            <div class="carousel-item @(count == 0 ? "active" : "")">
                                <img src="@img.ImageUrl" class="d-block w-100" style="height: 550px; object-fit: cover;" alt="Property">
                            </div>
                            count++;
                        }
                    }
                    else
                    {
                        <div class="carousel-item active">
                            <div class="bg-light d-flex align-items-center justify-content-center text-muted" style="height: 550px;">
                                <i class="fas fa-image fa-3x mb-2"></i> No Image Available
                            </div>
                        </div>
                    }
                </div>
                <button class="carousel-control-prev" type="button" data-bs-target="#propertyGallery" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon rounded-circle bg-dark p-3" aria-hidden="true"></span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#propertyGallery" data-bs-slide="next">
                    <span class="carousel-control-next-icon rounded-circle bg-dark p-3" aria-hidden="true"></span>
                </button>
            </div>

            <div class="glass-card p-5 mb-5 shadow-sm border-0 animate-fade-in">
                <div class="d-flex justify-content-between align-items-start mb-4">
                    <div>
                        <span class="badge btn-premium rounded-pill px-3 py-2 mb-3 shadow-none overflow-hidden" style="text-transform: none; letter-spacing: 0;">@Model.PropertyType</span>
                        <h1 class="fw-bold mb-2 display-5">@Model.Title</h1>
                        <p class="text-muted fs-5"><i class="fas fa-map-marker-alt text-danger me-2"></i>@Model.Address, @Model.District, @Model.City</p>
                    </div>
                </div>

                <div class="row g-4 mb-5 text-center">
                    <div class="col-md-3">
                        <div class="p-3 bg-light rounded-4 border border-white h-100 d-flex flex-column justify-content-center">
                            <div class="small text-muted mb-2 text-uppercase fw-bold">Giá thuê</div>
                            <div class="text-danger fw-bold h4 mb-0">@Model.Price.ToString("C0", new System.Globalization.CultureInfo("vi-VN"))</div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="p-3 bg-light rounded-4 border border-white h-100 d-flex flex-column justify-content-center">
                            <div class="small text-muted mb-2 text-uppercase fw-bold">Diện tích</div>
                            <div class="fw-bold h4 mb-0">@Model.Area m²</div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="p-3 bg-light rounded-4 border border-white h-100 d-flex flex-column justify-content-center">
                            <div class="small text-muted mb-2 text-uppercase fw-bold">Số phòng</div>
                            <div class="fw-bold h4 mb-0">@Model.NumberOfRooms</div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="p-3 bg-light rounded-4 border border-white h-100 d-flex flex-column justify-content-center">
                            <div class="small text-muted mb-2 text-uppercase fw-bold">Lượt xem</div>
                            <div class="fw-bold h4 mb-0"><i class="fas fa-eye text-muted me-2 small"></i>@Model.ViewCount</div>
                        </div>
                    </div>
                </div>

                <h5 class="fw-bold mb-4 border-bottom pb-3">Tiện ích đi kèm</h5>
                <div class="row g-3 mb-5">
                    @if (Model.PropertyAmenities != null && Model.PropertyAmenities.Any())
                    {
                        foreach (var pa in Model.PropertyAmenities)
                        {
                            <div class="col-lg-3 col-md-4 col-6">
                                <div class="amenity-pill p-3 border-0 bg-light rounded-4 shadow-sm h-100 d-flex align-items-center">
                                    <i class="@pa.Amenity?.Icon text-danger me-3 fs-4"></i>
                                    <span class="small fw-bold">@pa.Amenity?.Name</span>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="col-12 py-3 text-muted fst-italic">Phòng này chưa được gán tiện ích cụ thể.</div>
                    }
                </div>

                <h5 class="fw-bold mb-4 border-bottom pb-3">Mô tả chi tiết</h5>
                <p class="text-muted fs-6" style="white-space: pre-line; line-height: 1.8;">@Model.Description</p>
            </div>

            <!-- Reviews Section -->
            <div class="glass-card p-5 mt-4 shadow-sm border-0">
                <div class="d-flex justify-content-between align-items-center mb-5">
                    <h5 class="fw-bold mb-0 fs-4">Đánh giá từ khách hàng (@Model.Reviews.Count)</h5>
                    <div class="text-warning">
                        @{
                            var avgRating = Model.Reviews.Any() ? Model.Reviews.Average(r => r.Rating) : 0;
                        }
                        <span class="h3 fw-bold text-dark me-2">@avgRating.ToString("0.0")</span>
                        <div class="d-inline-block fs-5">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <i class="@(i <= Math.Round(avgRating) ? "fas" : "far") fa-star"></i>
                            }
                        </div>
                    </div>
                </div>

                <div class="reviews-wrapper mb-5">
                    @foreach (var review in Model.Reviews.OrderByDescending(r => r.CreatedAt))
                    {
                        <div class="p-4 rounded-4 bg-light mb-4 border border-white shadow-sm">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div class="d-flex align-items-center">
                                    <div class="avatar bg-white text-danger fw-bold rounded-circle border shadow-sm d-flex align-items-center justify-content-center me-3" style="width: 54px; height: 54px; font-size: 1.2rem;">
                                        @(review.User?.FullName?[0] ?? 'U')
                                    </div>
                                    <div>
                                        <div class="fw-bold">@(review.User?.FullName ?? "Khách hàng")</div>
                                        <div class="small text-muted">@review.CreatedAt.ToString("dd/MM/yyyy")</div>
                                    </div>
                                </div>
                                <div class="text-warning small fs-6">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <i class="@(i <= review.Rating ? "fas" : "far") fa-star"></i>
                                    }
                                </div>
                            </div>
                            <p class="mb-0 text-muted" style="line-height: 1.6;">@review.Comment</p>
                        </div>
                    }
                    @if (!Model.Reviews.Any())
                    {
                        <div class="text-center py-5 text-muted fst-italic">
                            <i class="far fa-comment-dots fa-3x mb-3 opacity-25"></i>
                            <p>Chưa có đánh giá nào cho phòng này.</p>
                        </div>
                    }
                </div>

                <div class="bg-light rounded-4 p-5 border border-white shadow-sm">
                    <h6 class="fw-bold mb-4 fs-5">Chia sẻ trải nghiệm của bạn</h6>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <form asp-controller="Reviews" asp-action="Create" method="post">
                            @Html.AntiForgeryToken()
                            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                            <input type="hidden" name="PropertyId" value="@Model.PropertyId" />
                            <div class="mb-4">
                                <div class="star-rating d-flex flex-row-reverse justify-content-start">
                                    <input type="radio" name="Rating" value="5" id="star5" checked /><label for="star5" class="fas fa-star fs-2 p-2"></label>
                                    <input type="radio" name="Rating" value="4" id="star4" /><label for="star4" class="fas fa-star fs-2 p-2"></label>
                                    <input type="radio" name="Rating" value="3" id="star3" /><label for="star3" class="fas fa-star fs-2 p-2"></label>
                                    <input type="radio" name="Rating" value="2" id="star2" /><label for="star2" class="fas fa-star fs-2 p-2"></label>
                                    <input type="radio" name="Rating" value="1" id="star1" /><label for="star1" class="fas fa-star fs-2 p-2"></label>
                                </div>
                            </div>
                            <div class="mb-4">
                                <textarea name="Comment" class="form-control border-0 rounded-4 px-4 py-3 shadow-none fs-6" rows="4" required placeholder="Cảm nghĩ của bạn về không gian sống này..."></textarea>
                            </div>
                            <button type="submit" class="btn btn-premium rounded-pill px-5 fw-bold py-3">GỬI ĐÁNH GIÁ</button>
                        </form>
                    }
                    else
                    {
                        <p class="text-center mb-0 py-2">Vui lòng <a asp-controller="Account" asp-action="Login" class="text-danger fw-bold text-decoration-none">đăng nhập</a> để tham gia đánh giá.</p>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="glass-card border-0 shadow-lg rounded-4 overflow-hidden sticky-top animate-slide-up" style="top: 100px; z-index: 10;">
                <div class="card-header border-0 p-4" style="background: var(--primary-gradient); color: white;">
                    <h5 class="fw-bold mb-0 text-center text-uppercase letter-spacing-1">Đặt lịch xem phòng</h5>
                </div>
                <div class="card-body p-4">
                    @if (Model.Status != "Available")
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-check-circle fa-4x text-success mb-4 opacity-25"></i>
                            <h4 class="fw-bold text-success mb-2">ĐÃ CHO THUÊ</h4>
                            <p class="text-muted small">Phòng này hiện đã có người thuê. Vui lòng quay lại sau hoặc tìm phòng khác.</p>
                            <a asp-action="Index" class="btn btn-outline-dark rounded-pill px-4 mt-3">Xem phòng khác</a>
                        </div>
                    }
                    else if (User.Identity?.IsAuthenticated == true)
                    {
                        <form asp-controller="Booking" asp-action="Create" method="post">
                            <input type="hidden" name="PropertyId" value="@Model.PropertyId" />
                            <div class="mb-4">
                                <label class="form-label fw-bold small text-uppercase mb-3 opacity-75">Ngày & Giờ dự kiến</label>
                                <div class="input-group bg-light rounded-4 p-1 border overflow-hidden">
                                    <span class="input-group-text bg-transparent border-0"><i class="far fa-clock text-danger fs-5"></i></span>
                                    <input type="text" name="AppointmentDate" id="appointmentPicker" class="form-control border-0 shadow-none bg-transparent py-3 fw-bold" readonly required placeholder="Chọn thời gian..." />
                                </div>
                            </div>
                            <div class="mb-4">
                                <label class="form-label fw-bold small text-uppercase mb-3 opacity-75">Ghi chú thêm</label>
                                <textarea name="Note" class="form-control border-0 bg-light rounded-4 px-3 py-3 shadow-none" rows="4" placeholder="Ví dụ: Tôi muốn xem vào buổi sáng..."></textarea>
                            </div>
                            <button type="submit" class="btn btn-premium w-100 py-3 rounded-pill fw-bold shadow-lg">XÁC NHẬN ĐẶT LỊCH</button>
                        </form>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-lock fa-4x text-muted mb-4 opacity-25"></i>
                            <p class="mb-4 text-muted fw-500">Vui lòng đăng nhập để gửi yêu cầu đặt lịch xem trực tiếp.</p>
                            <a asp-controller="Account" asp-action="Login" asp-route-returnUrl="@Context.Request.Path" class="btn btn-premium rounded-pill px-5 fw-bold w-100 py-3">ĐĂNG NHẬP</a>
                        </div>
                    }
                    <div class="mt-4 pt-4 border-top">
                        <div class="d-flex align-items-center text-muted small mb-3"><i class="fas fa-check-circle text-danger me-3 fs-6"></i>Hoàn toàn miễn phí xem tin</div>
                        <div class="d-flex align-items-center text-muted small"><i class="fas fa-phone-alt text-danger me-3 fs-6"></i>Hỗ trợ 24/7 qua Hotline</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            flatpickr("#appointmentPicker", {
                enableTime: true,
                dateFormat: "Y-m-d H:i",
                minDate: "today",
                time_24hr: true,
                minuteIncrement: 30,
                theme: "airbnb"
            });

            @if (TempData["SuccessMessage"] != null) {
                <text>Swal.fire({ icon: 'success', title: 'Thông báo', text: '@TempData["SuccessMessage"]', confirmButtonColor: '#ff385c' });</text>
            }
            @if (TempData["ErrorMessage"] != null) {
                <text>Swal.fire({ icon: 'error', title: 'Thông báo lỗi', text: '@TempData["ErrorMessage"]', confirmButtonColor: '#ff385c' });</text>
            }
        });
    </script>
}
