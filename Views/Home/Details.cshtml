@model DoAnWeb.Models.Property

@{
    ViewData["Title"] = Model.Title;
}

<nav aria-label="breadcrumb" class="my-4">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Trang chủ</a></li>
        <li class="breadcrumb-item active" aria-current="page">Chi tiết phòng</li>
    </ol>
</nav>

<div class="row">
    <div class="col-lg-8">
        <!-- Gallery -->
        <div id="propertyGallery" class="carousel slide shadow rounded overflow-hidden mb-4" data-bs-ride="carousel">
            <div class="carousel-inner">
                @{
                    int count = 0;
                    foreach (var img in Model.ImagesProperties.OrderByDescending(i => i.IsMain))
                    {
                        <div class="carousel-item @(count == 0 ? "active" : "")">
                            <img src="@img.ImageUrl" class="d-block w-100" style="height: 500px; object-fit: cover;" alt="Property Image">
                        </div>
                        count++;
                    }
                    if (count == 0)
                    {
                        <div class="carousel-item active">
                            <div class="bg-secondary d-flex align-items-center justify-content-center text-white" style="height: 500px;">
                                No Image Available
                            </div>
                        </div>
                    }
                }
            </div>
            @if (count > 1)
            {
                <button class="carousel-control-prev" type="button" data-bs-target="#propertyGallery" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#propertyGallery" data-bs-slide="next">
                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                </button>
            }
        </div>

        <div class="card shadow-sm border-0 p-4 mb-4">
            <h1 class="fw-bold text-dark">@Model.Title</h1>
            <p class="text-muted"><i class="fas fa-map-marker-alt text-danger"></i> @Model.Address, @Model.City</p>
            <hr />
            <div class="row text-center mb-4">
                <div class="col-4 border-end">
                    <p class="text-muted mb-1 small">Mức giá</p>
                    <h5 class="fw-bold text-primary">@Model.Price.ToString("C0", new System.Globalization.CultureInfo("vi-VN"))</h5>
                </div>
                <div class="col-4 border-end">
                    <p class="text-muted mb-1 small">Diện tích</p>
                    <h5 class="fw-bold">@Model.Area m²</h5>
                </div>
                <div class="col-4">
                    <p class="text-muted mb-1 small">Trạng thái</p>
                    <span class="badge @(Model.Status == "Available" ? "bg-success" : "bg-warning")">@Model.Status</span>
                </div>
            </div>
            <h5 class="fw-bold">Mô tả chi tiết</h5>
            <p style="white-space: pre-line;">@Model.Description</p>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card shadow border-0 sticky-top" style="top: 20px;">
            <div class="card-body p-4">
                <h4 class="fw-bold mb-4">Đặt lịch xem phòng</h4>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <form asp-controller="Booking" asp-action="Create" method="post">
                        <input type="hidden" name="PropertyId" value="@Model.PropertyId" />
                        <div class="mb-3">
                            <label class="form-label fw-bold">Ngày xem</label>
                            <input type="datetime-local" name="AppointmentDate" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Ghi chú (tùy chọn)</label>
                            <textarea name="Note" class="form-control" rows="3" placeholder="Ví dụ: Tôi muốn xem vào buổi sáng..."></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary w-100 py-2 fw-bold">Gửi yêu cầu đặt lịch</button>
                    </form>
                }
                else
                {
                    <div class="text-center py-4 bg-light rounded">
                        <p class="mb-3">Vui lòng đăng nhập để đặt lịch xem phòng</p>
                        <a asp-controller="Account" asp-action="Login" asp-route-returnUrl="@Context.Request.Path" class="btn btn-outline-primary btn-sm">Đăng nhập ngay</a>
                    </div>
                }
                <div class="mt-4 pt-4 border-top">
                    <p class="small text-muted"><i class="fas fa-info-circle"></i> Chúng tôi sẽ liên hệ lại với bạn để xác nhận lịch hẹn trong vòng 24h.</p>
                </div>
            </div>
        </div>
    </div>
</div>
